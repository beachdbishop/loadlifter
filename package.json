{
	"private": true,
	"scripts": {
		"development:tailwind:frontend": "npx postcss ./tailwind.css -o ./theme/style.css --verbose",
		"development:tailwind:slidercss": "npx postcss ./tailwind/a11y-slider.css -o ./theme/a11yslider.css",
		"development:tailwind:editor": "cross-env _TW_TARGET=editor npx postcss ./tailwind.css -o ./theme/style-editor.css",
		"development:tailwind:intellisense": "cross-env _TW_TARGET=intellisense npx postcss ./tailwind.css -o ./tailwind-intellisense.css",
		"development:esbuild": "npx esbuild ./javascript/script.js ./javascript/block-editor.js --target=esnext --bundle --outdir=./theme/js --out-extension:.js=.min.js",
		"development": "run-p \"development:**\"",
		"dev": "npm run development",
		"watch:tailwind:frontend": "npm run development:tailwind:frontend -- --watch",
		"watch:tailwind:slidercss": "npm run development:tailwind:slidercss -- --watch",
		"watch:tailwind:editor": "npm run development:tailwind:editor -- --watch",
		"watch:tailwind:intellisense": "npm run development:tailwind:intellisense -- --watch",
		"watch:esbuild": "npm run development:esbuild -- --watch",
		"watch:browser-sync": "browser-sync start --proxy \"https://peoplecptauthortest.local\" --files \"theme\" --no-notify --no-inject-changes --no-ghost-mode",
		"watch": "run-p \"watch:**\"",
		"production:tailwind:frontend": "cross-env _TW_ENV=production npm run development:tailwind:frontend",
		"production:tailwind:slidercss": "cross-env _TW_ENV=production npm run development:tailwind:slidercss -- --minify",
		"production:tailwind:editor": "cross-env _TW_ENV=production npm run development:tailwind:editor",
		"production:esbuild": "npm run development:esbuild -- --minify",
		"production": "run-p \"production:**\"",
		"prod": "npm run production",
		"zip": "node node_scripts/zip.js loadlifter",
		"bundle": "run-s production zip"
	},
	"devDependencies": {
		"@_tw/typography": "^0.5.22",
		"@tailwindcss/postcss": "^4.3.0",
		"a11y-slider": "^0.4.22",
		"adm-zip": "^0.5.16",
		"browser-sync": "^3.0.3",
		"cross-env": "^10.1.0",
		"cssnano": "^7.1.3",
		"esbuild": "^0.27.4",
		"npm-run-all": "^4.1.5",
		"postcss": "^8.5.8",
		"postcss-advanced-variables": "^5.0.0",
		"postcss-cli": "^11.0.1",
		"postcss-header": "^3.0.3",
		"postcss-import-ext-glob": "^2.1.1",
		"postcss-nesting": "^14.0.0",
		"tailwindcss": "^4.3.0"
	},
	"browserslist": [
		"defaults",
		"maintained node versions"
	]
}
