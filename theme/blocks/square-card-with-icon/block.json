{
	"$schema": "https://advancedcustomfields.com/schemas/json/main/block.json",
	"name": "loadlifter/square-card-with-icon",
	"title": "Square Card with Icon",
	"description": "A square card showing an icon and title that flips to reveal a message over a background image",
	"apiVersion": 2,
	"script": "block-square-card-with-icon",
	"category": "media",
	"icon": "<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 448 512'><!--!Font Awesome Pro v7.2.0 by @fontawesome - https://fontawesome.com License - https://fontawesome.com/license (Commercial License) Copyright 2026 Fonticons, Inc.--><path fill='#ce182d' d='M48 176l0 240c0 8.8 7.2 16 16 16l320 0c8.8 0 16-7.2 16-16l0-240-352 0zm200-48l141 0-40.9-57.3c-3-4.2-7.9-6.7-13-6.7l-87.1 0 0 64zM200 64l-87.1 0c-5.2 0-10 2.5-13 6.7L59 128 200 128 200 64zM0 148.5c0-13.3 4.2-26.3 11.9-37.2L60.9 42.8C72.9 26 92.3 16 112.9 16l222.1 0c20.7 0 40.1 10 52.1 26.8l48.9 68.5c7.8 10.9 11.9 23.9 11.9 37.2L448 416c0 35.3-28.7 64-64 64L64 480c-35.3 0-64-28.7-64-64L0 148.5zm214.9 90.4l9.1 9.1 9.1-9.1c9.5-9.5 22.5-14.9 36-14.9l2.9 0c26.5 0 48 21.5 48 48 0 53.4-66.9 95.7-89 108.2-4.4 2.5-9.6 2.5-14 0-22.1-12.5-89-54.8-89-108.2 0-26.5 21.5-48 48-48l2.9 0c13.5 0 26.5 5.4 36 14.9z'/></svg>",
	"keywords": ["card", "icon", "image", "text", "feature"],
	"style": "block-square-card-with-icon",
	"supports": {
		"align": false,
		"anchor": true,
		"alignContent": false,
		"background": false,
		"color": false,
		"alignText": false,
		"spacing": false,
		"fullHeight": false
	},
	"acf": {
		"mode": "auto",
		"blockVersion": 3,
		"renderTemplate": "render.php",
		"fields": [
			{
				"name": "ll_sqcard_title",
				"label": "Title",
				"type": "text",
				"required": 1,
				"conditional_logic": 0,
				"maxlength": 128
			},
			{
				"name": "ll_sqcard_icon",
				"label": "Icon",
				"type": "text",
				"instructions": "Provide the Font Awesome icon classes.",
				"required": 1,
				"conditional_logic": 0,
				"default_value": "fa-solid fa-globe",
				"maxlength": 255
			},
			{
				"name": "ll_sqcard_url",
				"label": "Link",
				"type": "text",
				"required": 1
			},
			{
				"name": "ll_sqcard_size",
				"label": "Size",
				"type": "radio",
				"required": 1,
				"conditional_logic": 0,
				"choices": {
					"small": "Small",
					"large": "Large"
				},
				"default_value": "small",
				"return_format": "value",
				"allow_null": 0,
				"other_choice": 0,
				"allow_in_bindings": 0,
				"layout": "horizontal",
				"save_other_choice": 0
			},
			{
				"name": "ll_sqcard_flip_enabled",
				"label": "Flip Enabled",
				"type": "true_false",
				"instructions": "",
				"required": 0,
				"conditional_logic": 0,
				"message": "Card flips by default, toggle off to disable flip behavior",
				"default_value": 1,
				"allow_in_bindings": 0,
				"ui": 0,
				"ui_on_text": "",
				"ui_off_text": ""
			},
			{
				"name": "ll_sqcard_bg_image",
				"label": "Background Image",
				"type": "image",
				"required": 0,
				"return_format": "array",
				"library": "all",
				"min_width": "",
				"min_height": "",
				"min_size": "",
				"max_width": "",
				"max_height": "",
				"max_size": "",
				"mime_types": "jpg,png,webp,avif",
				"allow_in_bindings": 0,
				"preview_size": "medium"
			},
			{
				"name": "ll_sqcard_message",
				"label": "Message",
				"type": "textarea",
				"instructions": "Keep it brief.",
				"required": 0,
				"rows": 4
			},
			{
				"name": "ll_sqcard_message_align",
				"label": "Message Alignment",
				"type": "radio",
				"required": 1,
				"conditional_logic": 0,
				"choices": {
					"center": "Center",
					"left": "Left (Long)"
				},
				"default_value": "center",
				"return_format": "value",
				"allow_null": 0,
				"other_choice": 0,
				"allow_in_bindings": 0,
				"layout": "horizontal",
				"save_other_choice": 0
			}
		]
	}
}
