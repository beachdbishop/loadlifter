{
	"$schema": "https://advancedcustomfields.com/schemas/json/main/block.json",
  "name": "loadlifter/color-chip",
  "title": "Color Chip",
  "description": "Block for displaying a theme color.",
  "apiVersion": 3,
  "category": "design",
  "icon": {
		"foreground": "#940418",
		"src": "color-picker"
	},
  "keywords": ["color", "colors"],
	"script": "",
	"style": "block-color-chip",
  "styles": [
    { "name": "default", "label": "Default", "isDefault": true },
    { "name": "brand", "label": "In Brand" }
  ],
  "supports": {
    "align": false,
    "anchor": true,
    "alignContent": false,
    "color": {
			"text": false,
			"background": false,
			"link": false
    },
    "alignText": false,
    "html": false,
    "jsx": true,
    "fullHeight": false,
		"customCSS": false
  },
  "attributes": {
  },
  "example": {
    "attributes": {
      "data": {
        "ll-color": "#ce182d",
        "ll-color-title": "Mahogany 700"
      }
    }
  },
  "acf": {
    "mode": "auto",
		"blockVersion": 3,
    "renderTemplate": "render.php"
  }
}
