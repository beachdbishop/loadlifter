{
	"$schema": "https://advancedcustomfields.com/schemas/json/main/block.json",
	"name": "loadlifter/ad",
	"title": "Ad",
	"description": "Block for displaying a cross-site ad/promo.",
	"apiVersion": 3,
	"category": "text",
	"icon": {
		"foreground": "#940418",
		"src": "embed-photo"
	},
	"keywords": ["ad", "promo", "banner"],
	"script": "",
	"style": "block-ad",
	"styles": [
		{ "name": "default", "label": "Default", "isDefault": true },
		{ "name": "brand-red", "label": "Brand Red" },
		{ "name": "brand-blue", "label": "Brand Blue" },
		{ "name": "brand-gray", "label": "Brand Gray" }
	],
	"supports": {
		"align": false,
		"anchor": true,
		"alignContent": false,
		"color": {
			"text": false,
			"background": false,
			"link": false
		},
		"alignText": false,
		"spacing": false,
		"fullHeight": false,
		"customCSS": false
	},
	"attributes": {
	},
	"example": {
		"attributes": {
			"data": {
				"ll-ad-text": "This is the ad lead.",
				"ll-ad-button-text": "Details"
			}
		}
	},
	"acf": {
		"mode": "auto",
		"blockVersion": 3,
		"renderTemplate": "render.php"
	}
}
